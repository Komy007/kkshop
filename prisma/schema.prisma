// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Language {
  code       String  @id @db.VarChar(5)
  name       String  @db.VarChar(50)
  isFrontend Boolean @default(true) @map("is_frontend")
  isAdmin    Boolean @default(false) @map("is_admin")

  productTranslations ProductTranslation[]

  @@map("languages")
}

model Category {
  id       BigInt  @id @default(autoincrement())
  slug     String  @unique @db.VarChar(50)   // e.g. skincare, makeup, new, best
  nameKo   String  @map("name_ko") @db.VarChar(100)
  nameEn   String  @map("name_en") @db.VarChar(100)
  nameKm   String  @map("name_km") @db.VarChar(100)
  nameZh   String  @map("name_zh") @db.VarChar(100)
  sortOrder Int    @default(0) @map("sort_order")
  isSystem  Boolean @default(false) @map("is_system") // true = 신상품/베스트 등 시스템 카테고리

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Product {
  id             BigInt    @id @default(autoincrement())
  sku            String    @unique @db.VarChar(100)
  priceUsd       Decimal   @map("price_usd") @db.Decimal(10, 2)
  stockQty       Int       @default(0) @map("stock_qty")
  categoryId     BigInt?   @map("category_id")
  status         String    @db.VarChar(20)   // ACTIVE | INACTIVE | SOLDOUT
  imageUrl       String?   @map("image_url") @db.VarChar(500)
  supplierId     String?   @map("supplier_id")
  isNew          Boolean   @default(false) @map("is_new")  // 신상품 여부
  // Rich product detail fields (non-translatable)
  volume         String?  @db.VarChar(100)
  skinType       String?  @map("skin_type") @db.VarChar(100)
  origin         String?  @db.VarChar(100)
  expiryMonths   Int?     @map("expiry_months")
  certifications String?  @db.VarChar(255)
  brandName      String?  @map("brand_name") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations ProductTranslation[]
  orderItems   OrderItem[]
  images       ProductImage[]
  supplier     Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([isNew])
  @@map("products")
}

model ProductImage {
  id        BigInt  @id @default(autoincrement())
  productId BigInt  @map("product_id")
  url       String  @db.VarChar(500)
  altText   String? @map("alt_text") @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductTranslation {
  id          BigInt  @id @default(autoincrement())
  productId   BigInt  @map("product_id")
  langCode    String  @map("lang_code") @db.VarChar(5)
  name        String  @db.VarChar(255)
  shortDesc   String? @map("short_desc") @db.VarChar(500)
  detailDesc  String? @map("detail_desc") @db.Text
  seoKeywords String? @map("seo_keywords") @db.VarChar(255)
  // Rich translatable fields
  ingredients String? @db.Text  // 주요 성분
  howToUse    String? @map("how_to_use") @db.Text  // 사용 방법
  benefits    String? @db.Text  // 효능/특징 (bullet points)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [langCode], references: [code], onDelete: Restrict)

  @@unique([productId, langCode])
  @@index([name])
  @@map("product_translations")
}

// ---------------------------------------------------------------------------
// Supplier (공급자/브랜드) System
// ---------------------------------------------------------------------------

model Supplier {
  id             String  @id @default(cuid())
  userId         String  @unique @map("user_id")
  companyName    String  @map("company_name") @db.VarChar(200)
  brandName      String? @map("brand_name") @db.VarChar(100)
  country        String? @db.VarChar(50)
  phone          String? @db.VarChar(50)
  contactEmail   String  @map("contact_email") @db.VarChar(255)
  logoUrl        String? @map("logo_url") @db.VarChar(500)
  description    String? @db.Text
  commissionRate Decimal @default(30) @map("commission_rate") @db.Decimal(5, 2)
  status         String  @default("PENDING") @db.VarChar(20)
  // PENDING, APPROVED, REJECTED, SUSPENDED
  adminNote      String? @map("admin_note") @db.Text

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

// ---------------------------------------------------------------------------
// NextAuth.js Authentication Models
// ---------------------------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime? @map("email_verified")
  image          String?
  hashedPassword String?
  role           String    @default("USER")
  // USER, ADMIN, SUPERADMIN, SUPPLIER
  phone          String?   @db.VarChar(50)
  address        String?   @db.VarChar(255)
  detailAddress  String?   @map("detail_address") @db.VarChar(255)
  postalCode     String?   @map("postal_code") @db.VarChar(20)
  accounts       Account[]
  sessions       Session[]
  orders         Order[]
  supplier       Supplier?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Site Settings
// ---------------------------------------------------------------------------

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ---------------------------------------------------------------------------
// Checkout and Orders Models
// ---------------------------------------------------------------------------

model Order {
  id            String      @id @default(cuid())
  userId        String?     @map("user_id")
  customerName  String      @map("customer_name") @db.VarChar(100)
  customerPhone String      @map("customer_phone") @db.VarChar(50)
  customerEmail String?     @map("customer_email") @db.VarChar(255)
  address       String      @db.VarChar(255)
  detailAddress String?     @map("detail_address") @db.VarChar(255)
  totalUsd      Decimal     @map("total_usd") @db.Decimal(10, 2)
  status        String      @default("PENDING") @db.VarChar(50)

  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  items OrderItem[]
  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId BigInt  @map("product_id")
  quantity  Int
  priceUsd  Decimal @map("price_usd") @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_items")
}
