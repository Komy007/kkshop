// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Language
// ---------------------------------------------------------------------------

model Language {
  code       String  @id @db.VarChar(5)
  name       String  @db.VarChar(50)
  isFrontend Boolean @default(true) @map("is_frontend")
  isAdmin    Boolean @default(false) @map("is_admin")

  productTranslations ProductTranslation[]
  reviewTranslations  ProductReviewTranslation[]

  @@map("languages")
}

// ---------------------------------------------------------------------------
// Category
// ---------------------------------------------------------------------------

model Category {
  id        BigInt    @id @default(autoincrement())
  slug      String    @unique @db.VarChar(50)
  nameKo    String    @map("name_ko") @db.VarChar(100)
  nameEn    String    @map("name_en") @db.VarChar(100)
  nameKm    String    @map("name_km") @db.VarChar(100)
  nameZh    String    @map("name_zh") @db.VarChar(100)
  sortOrder Int       @default(0) @map("sort_order")
  isSystem  Boolean   @default(false) @map("is_system")

  // Sub-category support
  parentId  BigInt?   @map("parent_id")
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")

  products  Product[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

// ---------------------------------------------------------------------------
// Product
// ---------------------------------------------------------------------------

model Product {
  id               BigInt   @id @default(autoincrement())
  sku              String   @unique @db.VarChar(100)
  priceUsd         Decimal  @map("price_usd") @db.Decimal(10, 2)
  stockQty         Int      @default(0) @map("stock_qty")
  categoryId       BigInt?  @map("category_id")
  status           String   @db.VarChar(20)       // ACTIVE | INACTIVE | SOLDOUT
  approvalStatus   String   @default("APPROVED") @map("approval_status") @db.VarChar(20)
  // PENDING (seller 미검수) | APPROVED | REJECTED
  imageUrl         String?  @map("image_url") @db.VarChar(500)
  supplierId       String?  @map("supplier_id")
  isNew            Boolean  @default(false) @map("is_new")
  isHotSale        Boolean  @default(false) @map("is_hot_sale")
  hotSalePrice     Decimal? @map("hot_sale_price") @db.Decimal(10, 2)
  reviewAvg        Decimal  @default(0) @map("review_avg") @db.Decimal(3, 2)
  reviewCount      Int      @default(0) @map("review_count")
  // Non-translatable spec fields
  volume           String?  @db.VarChar(100)
  skinType         String?  @map("skin_type") @db.VarChar(100)
  origin           String?  @db.VarChar(100)
  expiryMonths     Int?     @map("expiry_months")
  certifications   String?  @db.VarChar(255)
  brandName        String?  @map("brand_name") @db.VarChar(100)
  // Inventory & Cost fields
  costPrice        Decimal? @map("cost_price") @db.Decimal(10, 2)
  stockAlertQty    Int      @default(10) @map("stock_alert_qty")
  // Approval workflow
  rejectionReason     String?  @map("rejection_reason") @db.VarChar(500)
  // Trust badges — assigned by admin at approval time
  badgeAuthentic      Boolean  @default(false) @map("badge_authentic")
  badgeKoreanCertified Boolean @default(false) @map("badge_korean_certified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations  ProductTranslation[]
  orderItems    OrderItem[]
  images        ProductImage[]
  options       ProductOption[]
  variants      ProductVariant[]
  reviews       ProductReview[]
  stockLogs     StockLog[]
  wishlistItems Wishlist[]
  qa            ProductQA[]
  bundleItems   BundleItem[]
  flashSales    FlashSale[]
  supplier      Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  category      Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([supplierId])
  @@index([isNew])
  @@index([approvalStatus])
  @@index([isHotSale])
  @@index([status, categoryId])   // 카테고리별 활성 상품 조회 최적화
  @@map("products")
}

model ProductImage {
  id        BigInt  @id @default(autoincrement())
  productId BigInt  @map("product_id")
  url       String  @db.VarChar(500)
  altText   String? @map("alt_text") @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductTranslation {
  id          BigInt  @id @default(autoincrement())
  productId   BigInt  @map("product_id")
  langCode    String  @map("lang_code") @db.VarChar(5)
  name        String  @db.VarChar(255)
  shortDesc   String? @map("short_desc") @db.VarChar(500)
  detailDesc  String? @map("detail_desc") @db.Text
  seoKeywords String? @map("seo_keywords") @db.VarChar(255)
  ingredients String? @db.Text
  howToUse    String? @map("how_to_use") @db.Text
  benefits    String? @db.Text

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [langCode], references: [code], onDelete: Restrict)

  @@unique([productId, langCode])
  @@index([name])
  @@map("product_translations")
}

// ── 수량별 가격/혜택 옵션 ──────────────────────────────────────────────────
model ProductOption {
  id           BigInt   @id @default(autoincrement())
  productId    BigInt   @map("product_id")
  minQty       Int      @map("min_qty")           // 최소 수량
  maxQty       Int?     @map("max_qty")           // 최대 수량 (null = 무제한)
  discountPct  Decimal  @default(0) @map("discount_pct") @db.Decimal(5, 2)  // 할인율 %
  freeShipping Boolean  @default(false) @map("free_shipping")
  labelKo      String?  @map("label_ko") @db.VarChar(100) // 예: "2개 구매시 10% 할인"
  labelEn      String?  @map("label_en") @db.VarChar(100)
  labelKm      String?  @map("label_km") @db.VarChar(100)
  labelZh      String?  @map("label_zh") @db.VarChar(100)
  sortOrder    Int      @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_options")
}

// ── 상품 리뷰/평점 ─────────────────────────────────────────────────────────
model ProductReview {
  id            BigInt   @id @default(autoincrement())
  productId     BigInt   @map("product_id")
  userId        String   @map("user_id")
  orderId       String?  @map("order_id")          // 구매확인 연결
  rating        Int                                  // 1-5 점
  status        String   @default("PENDING") @db.VarChar(20)
  // PENDING | APPROVED | REJECTED
  imageUrl      String?  @map("image_url") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  product      Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  translations ProductReviewTranslation[]

  @@index([productId, status])
  @@index([userId])
  @@map("product_reviews")
}

model ProductReviewTranslation {
  id       BigInt  @id @default(autoincrement())
  reviewId BigInt  @map("review_id")
  langCode String  @map("lang_code") @db.VarChar(5)
  content  String  @db.Text

  review   ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  language Language      @relation(fields: [langCode], references: [code], onDelete: Restrict)

  @@unique([reviewId, langCode])
  @@map("product_review_translations")
}

// ---------------------------------------------------------------------------
// Supplier (공급자/브랜드)
// ---------------------------------------------------------------------------

model Supplier {
  id              String  @id @default(cuid())
  userId          String  @unique @map("user_id")
  companyName     String  @map("company_name") @db.VarChar(200)
  brandName       String? @map("brand_name") @db.VarChar(100)
  businessNumber  String? @map("business_number") @db.VarChar(50)  // 사업자번호
  ceoName         String? @map("ceo_name") @db.VarChar(100)        // 대표자명
  businessAddress String? @map("business_address") @db.VarChar(255) // 사업장주소
  country         String? @db.VarChar(50)
  phone           String? @db.VarChar(50)
  contactEmail    String  @map("contact_email") @db.VarChar(255)
  logoUrl         String? @map("logo_url") @db.VarChar(500)
  description     String? @db.Text
  commissionRate  Decimal @default(30) @map("commission_rate") @db.Decimal(5, 2)
  status          String  @default("PENDING") @db.VarChar(20)
  // PENDING | APPROVED | REJECTED | SUSPENDED
  adminNote       String? @map("admin_note") @db.Text

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

// ---------------------------------------------------------------------------
// Coupon System
// ---------------------------------------------------------------------------

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique @db.VarChar(50)
  descriptionKo   String?  @map("description_ko") @db.VarChar(200)
  descriptionEn   String?  @map("description_en") @db.VarChar(200)
  type            String   @db.VarChar(20)    // PERCENT | FIXED | FREE_SHIPPING
  discountValue   Decimal  @map("discount_value") @db.Decimal(10, 2)
  minOrderAmount  Decimal  @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  maxUses         Int?     @map("max_uses")   // null = 무제한
  usedCount       Int      @default(0) @map("used_count")
  startAt         DateTime @map("start_at")
  expireAt        DateTime @map("expire_at")
  isActive        Boolean  @default(true) @map("is_active")

  userCoupons UserCoupon[]
  orders      Order[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model UserCoupon {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  couponId String   @map("coupon_id")
  usedAt   DateTime? @map("used_at")
  orderId  String?  @map("order_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
  @@map("user_coupons")
}

// ---------------------------------------------------------------------------
// Point System
// ---------------------------------------------------------------------------

model UserPoint {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  amount      Int                         // 양수=적립, 음수=사용
  reason      String   @db.VarChar(200)  // 예: "주문 #OID 적립", "쿠폰 사용"
  balanceAfter Int     @map("balance_after")
  orderId     String?  @map("order_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_points")
}

// ---------------------------------------------------------------------------
// NextAuth.js Authentication Models
// ---------------------------------------------------------------------------

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime? @map("email_verified")
  image             String?
  hashedPassword    String?
  role              String    @default("USER")
  // USER | ADMIN | SUPERADMIN | SUPPLIER
  phone             String?   @db.VarChar(50)
  address           String?   @db.VarChar(255)
  detailAddress     String?   @map("detail_address") @db.VarChar(255)
  postalCode        String?   @map("postal_code") @db.VarChar(20)
  pointBalance      Int       @default(0) @map("point_balance")
  preferredLanguage String    @default("en") @map("preferred_language") @db.VarChar(5)
  referralCode      String?   @unique @map("referral_code") @db.VarChar(20)  // 내 추천 코드
  referredByCode    String?   @map("referred_by_code") @db.VarChar(20)       // 가입 시 사용한 추천 코드
  // 2FA (관리자 계정 보호)
  twoFactorSecret   String?   @map("two_factor_secret") @db.VarChar(255)
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")

  accounts         Account[]
  sessions         Session[]
  orders           Order[]
  supplier         Supplier?
  reviews          ProductReview[]
  points           UserPoint[]
  userCoupons      UserCoupon[]
  wishlistItems    Wishlist[]
  savedAddresses   UserAddress[]
  questionsAsked   ProductQA[]
  referralRewards      ReferralReward[]
  passwordResetTokens  PasswordResetToken[]
  emailVerifyTokens    EmailVerificationToken[]
  returnRequests       ReturnRequest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Site Settings
// ---------------------------------------------------------------------------

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ---------------------------------------------------------------------------
// Checkout and Orders
// ---------------------------------------------------------------------------

model Order {
  id              String   @id @default(cuid())
  userId          String?  @map("user_id")
  customerName    String   @map("customer_name") @db.VarChar(100)
  customerPhone   String   @map("customer_phone") @db.VarChar(50)
  customerEmail   String?  @map("customer_email") @db.VarChar(255)
  province        String?  @db.VarChar(100)
  address         String   @db.VarChar(255)
  detailAddress   String?  @map("detail_address") @db.VarChar(255)
  shippingFee     Decimal  @default(0) @map("shipping_fee") @db.Decimal(10, 2)
  subtotalUsd     Decimal  @map("subtotal_usd") @db.Decimal(10, 2)
  discountAmount  Decimal  @default(0) @map("discount_amount") @db.Decimal(10, 2)
  pointsUsed      Int      @default(0) @map("points_used")
  totalUsd        Decimal  @map("total_usd") @db.Decimal(10, 2)
  couponId        String?  @map("coupon_id")
  notes           String?  @db.VarChar(500)
  status          String   @default("PENDING") @db.VarChar(50)
  // PENDING | CONFIRMED | SHIPPING | DELIVERED | CANCELLED | REFUNDED | RETURN_REQUESTED
  paymentMethod   String?  @default("COD") @map("payment_method") @db.VarChar(50)
  // COD | ABA | KHQR | WING | BAKONG (Phase 7)
  paymentStatus   String   @default("PENDING") @map("payment_status") @db.VarChar(20)
  // PENDING | PAID | FAILED | REFUNDED

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items         OrderItem[]
  shipment      OrderShipment?
  returnRequest ReturnRequest?
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupon        Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId BigInt  @map("product_id")
  quantity  Int
  priceUsd  Decimal @map("price_usd") @db.Decimal(10, 2)
  optionId  BigInt? @map("option_id")   // 적용된 수량옵션
  variantId BigInt? @map("variant_id")  // 선택된 상품 옵션(색상/사이즈)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Stock Log (재고 변동 이력)
// ---------------------------------------------------------------------------

model StockLog {
  id           BigInt   @id @default(autoincrement())
  productId    BigInt   @map("product_id")
  changeQty    Int      @map("change_qty")     // 양수=입고, 음수=출고/손실
  balanceAfter Int      @map("balance_after")  // 변동 후 재고 수량
  reason       String   @db.VarChar(30)        // RECEIVED | SOLD | RETURN | DAMAGED | ADJUSTMENT | EXPIRED
  memo         String?  @db.VarChar(300)
  orderId      String?  @map("order_id")       // 주문 연결 (SOLD/RETURN 시)
  createdBy    String?  @map("created_by") @db.VarChar(255) // 처리 관리자 이메일

  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@map("stock_logs")
}

// ── 배송 추적 ───────────────────────────────────────────────────────────────
model OrderShipment {
  id              String   @id @default(cuid())
  orderId         String   @unique @map("order_id")
  carrier         String   @db.VarChar(100)      // 배송사 (예: CJ대한통운)
  trackingNumber  String   @map("tracking_number") @db.VarChar(100)
  trackingUrl     String?  @map("tracking_url") @db.VarChar(500)
  shippedAt       DateTime @map("shipped_at")
  estimatedAt     DateTime? @map("estimated_at")  // 예상 도착일
  deliveredAt     DateTime? @map("delivered_at")  // 실제 도착일
  memo            String?  @db.VarChar(300)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("order_shipments")
}

// ---------------------------------------------------------------------------
// Return / Refund Requests (반품 / 환불 요청)
// ---------------------------------------------------------------------------

model ReturnRequest {
  id          String    @id @default(cuid())
  orderId     String    @unique @map("order_id")
  userId      String    @map("user_id")
  reason      String    @db.VarChar(500)          // 고객이 입력한 반품 사유
  status      String    @default("PENDING") @map("status") @db.VarChar(20)
  // PENDING | APPROVED | REJECTED
  adminNote   String?   @map("admin_note") @db.VarChar(500)   // 관리자 메모
  processedBy String?   @map("processed_by") @db.VarChar(255) // 처리 관리자 이메일
  processedAt DateTime? @map("processed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([userId])
  @@map("return_requests")
}

// ---------------------------------------------------------------------------
// Product Variants (Color / Size)
// ---------------------------------------------------------------------------

model ProductVariant {
  id           BigInt   @id @default(autoincrement())
  productId    BigInt   @map("product_id")
  variantType  String   @map("variant_type") @db.VarChar(20)   // COLOR | SIZE | OTHER
  variantValue String   @map("variant_value") @db.VarChar(100) // "빨강/Red", "L", etc.
  sku          String?  @unique @db.VarChar(100)               // variant-specific SKU
  stockQty     Int      @default(0) @map("stock_qty")
  priceUsd     Decimal? @map("price_usd") @db.Decimal(10, 2)  // null = use product base price
  imageUrl     String?  @map("image_url") @db.VarChar(500)
  sortOrder    Int      @default(0) @map("sort_order")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

// ---------------------------------------------------------------------------
// Shipping Provinces (Cambodia)
// ---------------------------------------------------------------------------

model ShippingProvince {
  id          Int      @id @default(autoincrement())
  nameKo      String   @map("name_ko") @db.VarChar(100)
  nameEn      String   @map("name_en") @db.VarChar(100)
  nameKm      String   @map("name_km") @db.VarChar(100)
  nameZh      String   @map("name_zh") @db.VarChar(100)
  shippingFee Decimal  @default(3) @map("shipping_fee") @db.Decimal(10, 2)  // USD
  sortOrder   Int      @default(0) @map("sort_order")

  @@map("shipping_provinces")
}

// ---------------------------------------------------------------------------
// Wishlist (찜 목록)
// ---------------------------------------------------------------------------

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId BigInt   @map("product_id")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

// ---------------------------------------------------------------------------
// Product Q&A
// ---------------------------------------------------------------------------

model ProductQA {
  id          BigInt   @id @default(autoincrement())
  productId   BigInt   @map("product_id")
  userId      String   @map("user_id")
  question    String   @db.Text
  answer      String?  @db.Text
  status      String   @default("PENDING") @db.VarChar(20)
  // PENDING | ANSWERED | REJECTED
  answeredBy  String?  @map("answered_by") @db.VarChar(255)  // admin email
  answeredAt  DateTime? @map("answered_at")
  isPrivate   Boolean  @default(false) @map("is_private")    // 비밀 문의

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId, status])
  @@index([userId])
  @@map("product_qa")
}

// ---------------------------------------------------------------------------
// User Saved Addresses (주소록)
// ---------------------------------------------------------------------------

model UserAddress {
  id            String  @id @default(cuid())
  userId        String  @map("user_id")
  label         String  @db.VarChar(50)           // 예: "집", "회사"
  recipientName String  @map("recipient_name") @db.VarChar(100)
  phone         String  @db.VarChar(50)
  province      String  @db.VarChar(100)           // 캄보디아 주(Province)
  address       String  @db.VarChar(255)
  detailAddress String? @map("detail_address") @db.VarChar(255)
  isDefault     Boolean @default(false) @map("is_default")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_addresses")
}

// ---------------------------------------------------------------------------
// Flash Sale (타임세일)
// ---------------------------------------------------------------------------

model FlashSale {
  id            BigInt   @id @default(autoincrement())
  productId     BigInt   @map("product_id")
  salePriceUsd  Decimal  @map("sale_price_usd") @db.Decimal(10, 2)  // 타임세일 가격
  startAt       DateTime @map("start_at")
  endAt         DateTime @map("end_at")
  isActive      Boolean  @default(true) @map("is_active")
  labelKo       String?  @map("label_ko") @db.VarChar(100)
  labelEn       String?  @map("label_en") @db.VarChar(100)
  maxQtyPerUser Int?     @map("max_qty_per_user")                     // 1인 최대 구매 수량

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, startAt, endAt])
  @@map("flash_sales")
}

// ---------------------------------------------------------------------------
// Product Bundle / Gift Set (묶음/기획상품)
// ---------------------------------------------------------------------------

model ProductBundle {
  id           BigInt   @id @default(autoincrement())
  nameKo       String   @map("name_ko") @db.VarChar(200)
  nameEn       String   @map("name_en") @db.VarChar(200)
  nameKm       String   @default("") @map("name_km") @db.VarChar(200)
  nameZh       String   @default("") @map("name_zh") @db.VarChar(200)
  descKo       String?  @map("desc_ko") @db.Text
  descEn       String?  @map("desc_en") @db.Text
  coverImageUrl String? @map("cover_image_url") @db.VarChar(500)
  priceUsd     Decimal  @map("price_usd") @db.Decimal(10, 2)  // 묶음 판매가
  isActive     Boolean  @default(true) @map("is_active")

  items BundleItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_bundles")
}

model BundleItem {
  id       BigInt @id @default(autoincrement())
  bundleId BigInt @map("bundle_id")
  productId BigInt @map("product_id")
  quantity Int    @default(1)

  bundle  ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([bundleId, productId])
  @@map("bundle_items")
}

// ---------------------------------------------------------------------------
// Audit Log (관리자 행동 감사 기록)
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  userEmail  String   @map("user_email") @db.VarChar(255)
  userRole   String   @map("user_role") @db.VarChar(20)
  action     String   @db.VarChar(100)    // CREATE_PRODUCT, DELETE_USER, APPROVE_SUPPLIER 등
  resource   String?  @db.VarChar(100)    // products, users, orders 등
  resourceId String?  @map("resource_id") @db.VarChar(100)
  details    Json?                         // 변경 전후 데이터
  ipAddress  String?  @map("ip_address") @db.VarChar(45)

  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Referral System (추천인 시스템)
// ---------------------------------------------------------------------------

model ReferralReward {
  id              String   @id @default(cuid())
  referrerId      String   @map("referrer_id")      // 추천한 사람
  referredUserId  String   @map("referred_user_id") // 추천받아 가입한 사람
  pointsAwarded   Int      @map("points_awarded")   // 지급된 포인트

  referrer User @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([referrerId])
  @@map("referral_rewards")
}
