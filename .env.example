# =====================================================================
# KKShop Environment Variables — TEMPLATE
# =====================================================================
# 1. 이 파일을 복사해서 .env.local 또는 .env 로 저장하세요.
# 2. 실제 값을 채우세요.
# 3. .env / .env.local 은 절대 Git에 커밋하지 마세요!
# =====================================================================

# --- Database (Supabase PostgreSQL via PgBouncer) --------------------
# PgBouncer 연결 (포트 6543, 일반 쿼리용)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# 직접 연결 (포트 5432, prisma db push/migrate 전용)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- NextAuth.js -----------------------------------------------------
# 랜덤 시크릿 생성: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"
# 배포 URL (로컬: http://localhost:3000)
NEXTAUTH_URL="https://kkshop.cc"

# --- Google OAuth (소셜 로그인 — 없으면 비활성화) ----------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Google Cloud Storage (상품 이미지) --------------------------------
GCS_BUCKET_NAME="kkshop-images"
# 로컬 개발: 서비스 계정 JSON 파일 경로
GOOGLE_APPLICATION_CREDENTIALS="./google-key.json"
# Cloud Run: Workload Identity 또는 시크릿 마운트 사용

# --- Google Translate API --------------------------------------------
# 별도 키 없음 — GOOGLE_APPLICATION_CREDENTIALS 의 서비스 계정에서 사용

# --- Email SMTP (관리자 패널 /admin/settings/email 에서 설정) ----------
# SMTP 설정은 DB의 SiteSetting 테이블에 저장됩니다.
# 아래는 초기 세팅 전 환경변수로 지정할 경우 사용 (선택사항)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="app-password"

# --- 기타 ----------------------------------------------------------
NODE_ENV="development"
